// Mal — Third-Party Risk & Oversight Platform — data model
// Source of truth: /frontend Mal_ThirdParty_Risk_Oversight_Platform.jsx
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERVISOR
  CO
  MLRO
  ANALYST
  PARTNER
}

enum ControlStatus {
  OPERATING
  PARTIAL
  GAP
  NOT_IMPLEMENTED
}

enum CaseStatus {
  OPEN
  INVESTIGATING
  PENDING_QA
  SAR_FILED
  CLOSED_NO_SAR
  ESCALATED
}

enum Disposition {
  SAR
  NO_SAR
  ESCALATE
}

enum Severity {
  P1
  P2
  P3
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  role       Role
  createdAt  DateTime @default(now())
  casesOwned Case[]   @relation("assignee")
}

model Control {
  id          String        @id // e.g. "TM-1"
  domain      String
  requirement String
  expected    String        @db.Text
  citation    String
  risk        String // Critical / High / Medium / Low
  owner       String
  cadenceMo   Int
  status      ControlStatus @default(GAP)
  lastTested  DateTime?
  bsaPillar   String        @default("")
  fatf        String[] // ["R.10","R.12"]
  wolfsberg   String        @default("")
  evidence    Evidence[]
  tests       ControlTest[]
}

model Evidence {
  id        String   @id @default(cuid())
  control   Control  @relation(fields: [controlId], references: [id])
  controlId String
  name      String
  type      String
  uri       String? // object-store key when files are added
  addedBy   String   @default("seed")
  at        DateTime @default(now())
}

model ControlTest {
  id        String        @id @default(cuid())
  control   Control       @relation(fields: [controlId], references: [id])
  controlId String
  testedBy  String
  at        DateTime      @default(now())
  result    ControlStatus
}

model Typology {
  id          String   @id // "28"
  jur         String
  name        String
  category    String
  type        String   @default("")
  description String   @db.Text
  redFlags    String   @db.Text
  crossBorder Boolean  @default(false)
  defence     String[] // control ids this typology is defeated by
}

model Case {
  id            String       @id // "CASE-2026-0001"
  title         String
  severity      Severity
  status        CaseStatus   @default(OPEN)
  source        String
  customerRef   String // pseudonymous only — never real PII
  corridor      String
  amount        Int          @default(0)
  typologyId    String?
  controls      String[]
  assignee      User?        @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId    String?
  disposition   Disposition?
  rationale     String?      @db.Text
  reviewerId    String? // four-eyes; enforced != assigneeId
  reviewerName  String?
  approvedAt    DateTime?
  sarClockStart DateTime?
  narrative     String?      @db.Text
  openedAt      DateTime     @default(now())
  dpl           DplEntry[]
  sar           Sar?
}

model DplEntry {
  id     String   @id @default(cuid())
  case   Case     @relation(fields: [caseId], references: [id])
  caseId String
  who    String
  action String
  note   String   @db.Text
  at     DateTime @default(now())
}

model Sar {
  id        String   @id // "SAR-2026-0007"
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String   @unique
  subject   String
  typology  String
  narrative String   @db.Text
  amount    Int      @default(0)
  filedAt   DateTime @default(now())
}

model RegChange {
  id           String      @id // "RC-01"
  source       String
  type         String
  jurisdiction String
  date         String
  impact       String // high / med / low
  title        String
  summary      String      @db.Text
  action       String      @db.Text
  owner        String
  controls     String[]
  typologies   String[]
  task         ImpactTask?
}

model ImpactTask {
  id          String     @id @default(cuid())
  regChange   RegChange  @relation(fields: [regChangeId], references: [id])
  regChangeId String     @unique
  status      TaskStatus @default(OPEN)
  dueAt       DateTime
  owner       String
}

// Append-only, tamper-evident. Never UPDATE or DELETE rows.
// hash = sha256(prevHash + canonicalJson(record)). A broken chain = tampering.
model AuditLog {
  id       BigInt   @id @default(autoincrement())
  at       DateTime @default(now())
  actor    String
  role     Role
  action   String // "case.disposition.propose"
  entity   String
  entityId String
  payload  Json
  prevHash String?
  hash     String
}
