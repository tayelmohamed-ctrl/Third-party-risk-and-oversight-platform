{
  "name": "mal-fincrime-os",
  "version": "1.0.0",
  "private": true,
  "description": "Mal FinCrime OS — CRAM-centred Financial Crime Compliance Platform (Sayed · Mohsen · Jana)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "prisma generate && tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.758.0",
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.0.10",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.2",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.35",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vitest": "^3.2.6"
  }
}
