# PostgreSQL (docker-compose: postgres://cram:cram@localhost:5432/cram)
DATABASE_URL=postgresql://cram:cram@localhost:5433/cram

# Queue driver: postgres | sqs | kafka
QUEUE_DRIVER=postgres

# AWS SQS (when QUEUE_DRIVER=sqs)
AWS_REGION=me-central-1
SQS_FEED_QUEUE_URL=

# Kafka (when QUEUE_DRIVER=kafka) — start with: docker compose --profile kafka up -d
KAFKA_BROKERS=localhost:9092
KAFKA_FEED_TOPIC=cram.feed.events

# Auth: dev (header tokens) | oidc (JWT + JWKS)
AUTH_MODE=dev

# OIDC (when AUTH_MODE=oidc)
OIDC_ISSUER=https://your-bank-idp.example.com
OIDC_AUDIENCE=cram-api
OIDC_JWKS_URI=
OIDC_CLIENT_ID=cram-console
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5174/auth/callback
OIDC_SCOPES=openid profile email
# IdP group → CRAM role JSON map (optional — defaults built-in)
# OIDC_GROUP_MAP={"cram-mlro":"MLRO","cram-reviewer":"Reviewer"}
OIDC_ROLE_CLAIM=groups
# Allow dev bearer tokens alongside OIDC (local testing only)
# OIDC_ALLOW_DEV_FALLBACK=1
# Allow X-CRAM-User headers for service pipelines
# OIDC_ALLOW_HEADER_AUTH=1

# Frontend (Vite)
VITE_AUTH_MODE=dev

# goAML / FinCEN FIU submission (Phase 2 — mock by default)
GOAML_MODE=mock
GOAML_ENTITY_ID=MAL-BANK-AE
GOAML_API_BASE=https://services.uaeiec.gov.ae/goaml/api
GOAML_API_KEY=
FINCEN_MODE=mock
FINCEN_API_BASE=
FINCEN_API_KEY=

# Server
PORT=3010
SCHEDULER_DEMO=1

# Sayed — regulatory monitor (production)
# Tier-1 RSS (primary) · HTTP hash (backup) · notify Walid on change
REG_RSS_CBUAE=https://www.centralbank.ae/en/rss-feeds/rss.ashx?type=circulars
REG_RSS_FINCEN=https://www.fincen.gov/news/rss.xml
REG_ALERT_EMAIL_TO=walid.elsheikha@mal.ae
REG_ALERT_EMAIL_FROM=compliance@mal.ae
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
# Zenus BaaS addendum — bump version when partner publishes update
ZENUS_ADDENDUM_VERSION=2026-Q2-v1.3
ZENUS_ADDENDUM_DRIVE_FILE_ID=
ZENUS_ADDENDUM_DRIVE_PATH=Partners/Zenus/BaaS-Compliance-Addendum

# Vital4 — sanctions / PEP / adverse (Phase 1a sole screening authority)
# Omit VITAL4_API_KEY for mock mode in local dev
VITAL4_MODE=mock
VITAL4_API_BASE=https://api.vital4.net
VITAL4_API_KEY=
VITAL4_WEBHOOK_SECRET=

# Future partners (Phase 1b+)
SHUFTIPRO_API_KEY=
SHUFTIPRO_WEBHOOK_SECRET=
AIPRISE_API_KEY=
AIPRISE_WEBHOOK_SECRET=
OSCILAR_API_KEY=
OSCILAR_WEBHOOK_SECRET=
